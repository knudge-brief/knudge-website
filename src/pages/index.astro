<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Knudge — News Intelligence</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400&display=swap" rel="stylesheet">
<link rel="icon" type="image/png" href="/favicon.png">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --ink: #1A1A18;
    --paper: #F5F2EC;
    --rule: #D6D0C4;
    --accent: #C8392B;
    --muted: #7A7668;
    --highlight: #EDE8DF;
  }

  html, body {
    height: 100%;
    overflow: hidden;
    background: var(--paper);
    color: var(--ink);
    font-family: 'DM Sans', sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  .page {
    height: 100dvh;
    max-width: 430px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    border-left: 1px solid var(--rule);
    border-right: 1px solid var(--rule);
    overflow: hidden;
  }

  /* ── MASTHEAD ── */
  .masthead {
    padding: 10px 22px 8px;
    border-bottom: 2.5px solid var(--ink);
    display: flex;
    align-items: center;
    flex-shrink: 0;
    animation: fadeDown 0.4s ease both;
  }

  .logo-img {
    height: 62px;
    width: auto;
    display: block;
  }

  /* ── HERO ── */
  .hero {
    padding: 10px 22px 10px;
    border-bottom: 1px solid var(--rule);
    flex-shrink: 0;
    animation: fadeDown 0.4s 0.07s ease both;
  }

  .kicker {
    font-family: 'DM Mono', monospace;
    font-size: 8px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 5px;
  }

  .headline {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    line-height: 1.18;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 6px;
  }

  .headline em {
    font-style: italic;
    font-weight: 400;
  }

  .deck {
    font-size: 11px;
    line-height: 1.5;
    color: var(--muted);
    font-weight: 300;
  }

  /* ── BRIEF SECTION ── */
  .brief-section {
    padding: 8px 22px 0;
    flex-shrink: 0;
    animation: fadeUp 0.4s 0.13s ease both;
  }

  .section-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 9px;
  }

  .section-label {
    font-family: 'DM Mono', monospace;
    font-size: 8px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    padding-top: 2px;
    flex-shrink: 0;
  }

  .persona-block {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 5px;
  }

  .persona-pill {
    display: flex;
    align-items: center;
    gap: 5px;
    background: var(--highlight);
    border: 1px solid var(--rule);
    border-radius: 20px;
    padding: 3px 8px 3px 4px;
  }

  .persona-avatar {
    width: 15px;
    height: 15px;
    border-radius: 50%;
    background: var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 7px;
    font-weight: 500;
    color: var(--paper);
    flex-shrink: 0;
  }

  .persona-pill-name {
    font-size: 8.5px;
    font-weight: 400;
    color: var(--ink);
    white-space: nowrap;
  }

  .interest-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 3px;
    justify-content: flex-end;
  }

  .interest-tag {
    font-family: 'DM Mono', monospace;
    font-size: 7px;
    color: var(--muted);
    background: var(--paper);
    border: 1px solid var(--rule);
    border-radius: 2px;
    padding: 1px 5px;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  /* ── PERSONA STORY ── */
  .persona-story {
    font-size: 13.5px;
    color: var(--ink);
    font-weight: 300;
    line-height: 1.55;
    font-style: italic;
    margin-bottom: 10px;
    padding-bottom: 7px;
    border-bottom: 1px solid var(--rule);
  }

  .persona-brief-label {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-bottom: 9px;
    text-transform: uppercase;
  }

  /* ── BRIEF CARDS ── */
  .brief-cards {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .brief-card {
    background: var(--highlight);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 7px 10px;
  }

  .brief-card-category {
    font-family: 'DM Mono', monospace;
    font-size: 7px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 3px;
  }

  .brief-card-headline {
    font-size: 10px;
    font-weight: 500;
    line-height: 1.38;
    color: var(--ink);
    margin-bottom: 5px;
  }

  .brief-card-impact {
    font-size: 9.5px;
    color: var(--ink);
    font-weight: 300;
    line-height: 1.45;
    padding-top: 5px;
    border-top: 1px solid var(--rule);
  }

  .brief-card-impact strong {
    font-weight: 600;
    color: var(--accent);
  }

  .more-stories {
    margin-top: 6px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--rule);
    font-family: 'DM Mono', monospace;
    font-size: 7.5px;
    color: var(--muted);
    letter-spacing: 0.06em;
  }

  .more-stories span { color: var(--accent); }

  /* ── FOOTER ── */
  .footer {
    border-top: 2.5px solid var(--ink);
    padding: 10px 22px 12px;
    background: var(--ink);
    flex-shrink: 0;
    flex-grow: 1;
    animation: fadeUp 0.4s 0.2s ease both;
  }

  .footer-top {
    margin-bottom: 9px;
  }

  .footer-label {
    font-family: 'DM Mono', monospace;
    font-size: 8px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #C8C4BC;
  }

  .waitlist-row {
    display: flex;
    gap: 8px;
  }

  .email-input {
    flex: 1;
    background: transparent;
    border: 1px solid #3A3A38;
    border-radius: 2px;
    padding: 10px 12px;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: var(--paper);
    outline: none;
    transition: border-color 0.2s;
    min-width: 0;
  }

  .email-input::placeholder { color: #4A4A46; }
  .email-input:focus { border-color: #7A7A70; }

  .join-btn {
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 2px;
    padding: 10px 16px;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.15s, transform 0.1s;
    flex-shrink: 0;
  }

  .join-btn:active { transform: scale(0.97); }
  .join-btn:hover { opacity: 0.88; }

  .footer-subtext {
    font-size: 9px;
    color: #9A9A90;
    margin-top: 9px;
    line-height: 1.5;
  }

  .success-msg {
    display: none;
    align-items: center;
    gap: 8px;
    color: #7DBD7A;
    font-size: 11px;
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.04em;
    margin-top: 6px;
  }
  .success-msg.show { display: flex; }

  @keyframes fadeDown {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (min-width: 500px) and (max-width: 899px) {
    body { background: #E8E4DC; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
    html, body { height: auto; overflow: auto; }
    .page { height: 100dvh; max-height: 860px; box-shadow: 0 8px 40px rgba(0,0,0,0.15); border: none; }
  }

  @media (min-width: 900px) {
    body { 
      background: var(--paper); 
      display: flex; 
      align-items: center; 
      justify-content: center; 
      min-height: 100vh; 
    }
    html, body { height: auto; overflow: auto; }
    
    .page { 
      height: 100vh;
      min-height: 600px;
      max-width: 1080px; 
      width: 100%;
      margin: 0 auto;
      box-shadow: none; 
      border: none;
      display: grid;
      grid-template-columns: 1fr 480px;
      grid-template-rows: auto auto auto;
      align-content: center;
      gap: 0 80px;
      padding: 40px;
      overflow: visible;
    }

    .masthead { 
      grid-column: 1; 
      grid-row: 1; 
      border-bottom: none; 
      padding: 0; 
      margin-bottom: 50px;
      animation: fadeDown 0.6s ease both;
    }
    .logo-img { height: 100px; }

    .hero { 
      grid-column: 1; 
      grid-row: 2; 
      border-bottom: none; 
      padding: 0; 
      margin-bottom: 50px;
      animation: fadeDown 0.6s 0.1s ease both;
    }
    .kicker { font-size: 11px; margin-bottom: 16px; }
    .headline { font-size: 56px; line-height: 1.05; margin-bottom: 24px; letter-spacing: -0.02em; }
    .deck { font-size: 18px; line-height: 1.5; max-width: 440px; }

    .brief-section { 
      grid-column: 2; 
      grid-row: 1 / span 3; 
      align-self: center;
      background: #fff; 
      border: 1px solid var(--rule); 
      border-radius: 16px; 
        
      box-shadow: 0 24px 48px rgba(0,0,0,0.06);
      overflow-y: auto;
      animation: fadeUp 0.6s 0.2s ease both;
      width: 100%;
    }
    
    .brief-section::-webkit-scrollbar { width: 0; }
    .brief-section { scrollbar-width: none; }

    .brief-card {
      transition: transform 0.2s ease, box-shadow 0.2s ease; gap: 15px;padding: 10px 15px;
    }
    .brief-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 16px rgba(0,0,0,0.06);
    }

    .brief-card-category {
      font-size: 10px;
    }

    .brief-card-headline {
      font-size: 15px;
      line-height: 1.2;
    }

    .brief-card-impact {
      font-size: 13px;
      line-height: 1.4;
    }

    .persona-story {
      font-size: 20px;
      line-height: 1.3;
    }

    .footer { 
      grid-column: 1; 
      grid-row: 3; 
      background: transparent; 
      border-top: none; 
      padding: 0; 
      animation: fadeUp 0.6s 0.3s ease both;
    }
    
    .footer-top { margin-bottom: 16px; }
    .footer-label { 
      color: var(--ink); 
      font-size: 11px; 
      font-weight: 600;
    }
    .email-input { 
      border: 1px solid var(--rule); 
      color: var(--ink); 
      font-size: 15px;
      padding: 14px 18px;
      border-radius: 4px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.02);
    }
    .email-input::placeholder { color: #A09C90; }
    .email-input:focus { border-color: var(--ink); background: #fff;}
    .join-btn {
      font-size: 15px;
      padding: 14px 28px;
      border-radius: 4px;
      box-shadow: 0 4px 12px rgba(200, 57, 43, 0.2);
    }
    .footer-subtext { 
      color: var(--muted); 
      font-size: 12px;
      margin-top: 12px;
    }
    .success-msg {
      color: #58A055;
      font-size: 14px;
    }
  }

  @media (min-width: 1200px) {
    .page { max-width: 1200px; gap: 0 100px; }
    .headline { font-size: 64px; }
    .deck { font-size: 20px; max-width: 500px; }
    .brief-section { padding: 40px 32px; }
  }
</style>
</head>
<body>

<div class="page">
  <header class="masthead">
  <img src="/logo_knudge.png" alt="Knudge_Logo" class="logo-img" />
</header>

  <section class="hero">
<h1 class="headline">Personalized news that tells you<br><em>what to do.</em></h1>
    <p class="deck">Filtered for your life, not an algorithm's guess. Every story comes with a clear next step.</p>
  </section>

  <section class="brief-section">
    <div class="section-header">
      <div class="section-label">Sample Brief</div>
    </div>
    <p class="persona-story">Rohan, 28. Works in tech, lives in Koramangala. Watching his job market, planning his first car, and keeping an eye on Bangalore rents.</p>
    <p class="persona-brief-label">Here's his news brief for today.</p>

    <div class="brief-cards">
      <div class="brief-card">
        <div class="brief-card-category">Job Security</div>
        <div class="brief-card-headline">Wipro and HCL extend appraisal freeze, no variable pay confirmed for Q2</div>
        <div class="brief-card-impact"><strong>Takeaway —</strong> This isn't just Wipro and HCL. If your company hasn't announced appraisal dates yet, assume they're watching the same numbers. Don't wait to be told. Have a casual check-in with your manager this week. Be the person who stayed informed, not the one who was caught off guard.</div>
      </div>

      <div class="brief-card">
        <div class="brief-card-category">Car Purchase</div>
        <div class="brief-card-headline">Maruti Suzuki Swift waitlist hits 14 weeks in Bangalore dealerships</div>
        <div class="brief-card-impact"><strong>Takeaway —</strong> 14 weeks means you're buying in Q3 at current prices. If you're serious, book now and lock the price. If you're still on the fence, use those 14 weeks to actually run the numbers. EMI plus insurance plus Bangalore parking will surprise you.</div>
      </div>

      <div class="brief-card">
        <div class="brief-card-category">Bangalore</div>
        <div class="brief-card-headline">2BHK rents in Koramangala cross ₹40,000 for the first time</div>
        <div class="brief-card-impact"><strong>Takeaway —</strong> If you're not at ₹40k yet, your renewal notice is coming. Start the conversation with your landlord before they do. And quietly check what's available in HSR and Bellandur. Same quality, 20% cheaper, and the metro's coming.</div>
      </div>
    </div>

    <div class="more-stories"><span>+</span> 4 more stories in your brief today</div>
  </section>

  <footer class="footer">
    <div class="footer-top">
      <div class="footer-label">Get Early Access</div>
    </div>
    <form class="waitlist-row" id="waitlistForm">
      <input type="hidden" name="access_key" value="d3c1370a-73ff-4ba9-9e6a-4227e3a2bcb6">
      <input type="hidden" name="subject" value="New Waitlist Signup for Knudge">
      <input type="hidden" name="from_name" value="Knudge Waitlist">
      <input class="email-input" type="email" name="email" id="emailInput" placeholder="your@email.com" autocomplete="email" required>
      <button class="join-btn" type="submit" id="joinBtn">Join now</button>
    </form>
    <div class="success-msg" id="successMsg">✦ You're on the list.</div>
    <p class="footer-subtext">No spam. One ping when Knudge launches.</p>
  </footer>

</div>

<script>
  const waitlistForm = document.getElementById('waitlistForm');
  waitlistForm.addEventListener('submit', function(e) {
    e.preventDefault();
    
    const input = document.getElementById('emailInput');
    const msg = document.getElementById('successMsg');
    const btn = document.getElementById('joinBtn');
    
    const email = input.value.trim();
    const valid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    if (!valid) {
      input.style.borderColor = '#C8392B';
      input.focus();
      setTimeout(() => input.style.borderColor = '', 1200);
      return;
    }
    
    // UI Loading state
    const originalBtnText = btn.innerText;
    btn.innerText = 'Joining...';
    btn.disabled = true;

    const formData = new FormData(waitlistForm);
    const object = Object.fromEntries(formData);
    const json = JSON.stringify(object);

    fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
        },
        body: json
    })
    .then(async (response) => {
        let json = await response.json();
        if (response.status == 200) {
            waitlistForm.style.display = 'none';
            msg.classList.add('show');
        } else {
            console.log(response);
            btn.innerText = originalBtnText;
            btn.disabled = false;
            alert(json.message || "Something went wrong! Please try again.");
        }
    })
    .catch(error => {
        console.log(error);
        btn.innerText = originalBtnText;
        btn.disabled = false;
        alert("Something went wrong! Please try again.");
    });
  });
</script>

</body>
</html>
