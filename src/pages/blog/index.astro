---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);

// Sort by date descending
const posts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat("en-IN", {
    day: "numeric",
    month: "long",
    year: "numeric",
  }).format(date);
}
---

<BaseLayout
  title="Journal — knudge"
  description="Ideas on personalization, information overload, and why most news products are built for the wrong person."
>
  <!-- Blog hero -->
  <section class="blog-hero">
    <div class="container">
      <div class="section-label reveal">From the knudge journal</div>
      <h1 class="blog-headline reveal">
        Ideas we're<br />thinking through.
      </h1>
      <p class="blog-sub reveal reveal-delay-1">
        On personalization, information overload, and why most news products are
        built for the wrong person.
      </p>
    </div>
  </section>

  <!-- Post listing -->
  <section class="blog-grid">
    <div class="container">
      {
        posts.length === 0 ? (
          <p class="blog-empty">
            The first post is being written. Check back soon — or{" "}
            <a
              href="#early-access"
              style="color: var(--color-gold); text-decoration: none;"
            >
              join the broadcast group
            </a>{" "}
            to get it first.
          </p>
        ) : (
          posts.map((post) => (
            <a href={`/blog/${post.id}`} class="blog-post-item reveal">
              <div class="blog-post-meta">
                <div>{formatDate(post.data.date)}</div>
                <div style="margin-top: 0.25rem">{post.data.readTime}</div>
              </div>
              <div>
                <h2 class="blog-post-title">{post.data.title}</h2>
                <p class="blog-post-desc">{post.data.description}</p>
              </div>
            </a>
          ))
        )
      }
    </div>
  </section>

  <!-- Bottom CTA -->
  <section
    style="padding: 5rem 0; border-top: 1px solid var(--color-border);"
    id="early-access"
  >
    <div class="container">
      <div style="max-width: 480px;">
        <p
          style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 400; color: var(--color-cream); margin: 0 0 1.5rem; line-height: 1.3;"
        >
          Get each post + early briefs in the broadcast group.
        </p>
        <div class="early-actions">
          <a
            href="https://t.me/YOUR_TELEGRAM_LINK"
            target="_blank"
            rel="noopener"
            class="btn-telegram"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221l-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12l-6.871 4.326-2.962-.924c-.643-.204-.657-.643.136-.953l11.57-4.461c.537-.194 1.006.131.833.941z"
              ></path>
            </svg>
            Telegram
          </a>
          <a
            href="https://wa.me/YOUR_WHATSAPP_LINK"
            target="_blank"
            rel="noopener"
            class="btn-whatsapp"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
              ></path>
            </svg>
            WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
