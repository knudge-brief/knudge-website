---
const pathname = Astro.url.pathname;
---

<header class="nav" id="nav">
  <div class="container">

    <!-- Top bar: [logo ←————————————————→ button] -->
    <div class="nav-inner">

      <a href="/" class="nav-logo">knud<span>ge</span></a>

      <!-- Desktop links — hidden on mobile -->
      <nav class="nav-menu" aria-label="Main navigation">
        <ul class="nav-links">
          <li>
            <a href="/blog" class:list={[{ active: pathname.startsWith("/blog") }]}>
              Journal
            </a>
          </li>
          <li>
            <a
              href="https://www.instagram.com/lifewithanugrah"
              target="_blank"
              rel="noopener noreferrer"
            >Behind the build ↗</a>
          </li>
          <li>
            <a href="#early-access" class="nav-cta">Join early access</a>
          </li>
        </ul>
      </nav>

      <!-- Hamburger — always rightmost, hidden on desktop -->
      <button
        class="nav-mobile-toggle"
        id="nav-toggle"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="nav-drawer"
      >
        <svg id="icon-menu" width="22" height="22" viewBox="0 0 22 22"
          fill="none" stroke="currentColor" stroke-width="1.5"
          stroke-linecap="round" aria-hidden="true">
          <path d="M3 6h16M3 11h16M3 16h16"></path>
        </svg>
        <svg id="icon-close" width="22" height="22" viewBox="0 0 22 22"
          fill="none" stroke="currentColor" stroke-width="1.5"
          stroke-linecap="round" aria-hidden="true" style="display:none">
          <path d="M4 4l14 14M18 4L4 18"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile drawer — below top bar, full width -->
    <div class="nav-drawer" id="nav-drawer" aria-hidden="true">
      <ul>
        <li><a href="/blog">Journal</a></li>
        <li>
          <a href="https://www.instagram.com/lifewithanugrah"
            target="_blank" rel="noopener noreferrer">
            Behind the build ↗
          </a>
        </li>
        <li>
          <a href="#early-access" class="drawer-cta">Join early access →</a>
        </li>
      </ul>
    </div>

  </div>
</header>

<script>
  const navEl     = document.getElementById("nav");
  const toggle    = document.getElementById("nav-toggle");
  const drawer    = document.getElementById("nav-drawer");
  const iconMenu  = document.getElementById("icon-menu");
  const iconClose = document.getElementById("icon-close");

  // Frosted nav on scroll
  window.addEventListener("scroll", () => {
    navEl?.classList.toggle("scrolled", window.scrollY > 40);
  }, { passive: true });

  function setOpen(open: boolean) {
    drawer?.classList.toggle("open", open);
    toggle?.setAttribute("aria-expanded", String(open));
    drawer?.setAttribute("aria-hidden", String(!open));
    toggle?.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    if (iconMenu && iconClose) {
      (iconMenu  as HTMLElement).style.display = open ? "none"  : "block";
      (iconClose as HTMLElement).style.display = open ? "block" : "none";
    }
  }

  toggle?.addEventListener("click", () => {
    setOpen(!drawer?.classList.contains("open"));
  });

  drawer?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => setOpen(false));
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") setOpen(false);
  });
</script>
